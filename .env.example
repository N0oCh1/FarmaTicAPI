# Variables de Entorno - Copia a .env y completa con tus valores reales
# NUNCA confirmes el archivo .env a control de versiones

# ─── Servidor ─────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ─── Base de Datos PostgreSQL ─────────────────────────────────────────────────
# Formato: postgres://usuario:contraseña@host:puerto/base_datos
# Reemplaza los valores con tu configuración de PostgreSQL
DB_URL=postgres://postgres:tu_contraseña@localhost:5432/farmatica

# ─── Autenticación JWT (para futuras implementaciones) ───────────────────────
# Usa un secreto fuerte y aleatorio en producción (ej: openssl rand -hex 64)
JWT_SECRET=cambia_esto_por_un_secreto_fuerte_y_aleatorio
JWT_EXPIRES_IN=7d

