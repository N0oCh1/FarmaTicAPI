# Environment variables – copy to .env and fill in real values.
# NEVER commit the .env file to version control.

# ─── Server ──────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ─── JWT ─────────────────────────────────────────────────────────────────────
# Use a strong, random secret in production (e.g. openssl rand -hex 64)
JWT_SECRET=change_me_to_a_strong_secret
JWT_EXPIRES_IN=1h

# ─── Database ─────────────────────────────────────────────────────────────────
# Replace with your real connection string
DB_URI=mongodb://localhost:27017/farmaticapi
